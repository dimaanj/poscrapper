# Telegram API credentials — get from https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=

# Phone number in international format, e.g. +79001234567
TG_PHONE=

# Comma-separated channel usernames (without @), e.g.: nodejs_jobs,it_vacancies,remote_jobs_ru
TG_CHANNELS=

# Your CV PDF link (Google Drive, Notion, etc.)
CV_LINK=

# Your contact email shown in messages
CV_EMAIL=tomashevichdmitry@gmail.com

# API server port (default 3000)
PORT=3000
